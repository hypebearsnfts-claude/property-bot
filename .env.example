# ── Telegram ─────────────────────────────────────────────────────────────────
# Create a bot via @BotFather on Telegram and paste the token here.
# All three variables should use the same token (one bot handles everything).
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_RESEARCH_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_FILTER_BOT_TOKEN=your-telegram-bot-token

# Your personal Telegram chat ID (send /start to @userinfobot to find it).
TELEGRAM_RESEARCH_CHAT_ID=your-chat-id
TELEGRAM_FILTER_CHAT_ID=your-chat-id

# ── Google Maps ───────────────────────────────────────────────────────────────
# Used for walk-time calculations to nearest tube station.
# Create a key at https://console.cloud.google.com → enable "Distance Matrix API".
GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# ── Anthropic ─────────────────────────────────────────────────────────────────
# Used for AI-powered FMV valuation.
# Get a key at https://console.anthropic.com
ANTHROPIC_API_KEY=your-anthropic-api-key

# ── Filter bot limits ─────────────────────────────────────────────────────────
# Max listings to send per Telegram run (0 = no limit).
MAX_LISTINGS_SEND=0

# Max walk time to nearest tube station in minutes.
MAX_WALK_MINS=12

# ── Portal credentials (optional) ─────────────────────────────────────────────
# Rightmove and Zoopla removed guest enquiry forms in 2022/2023 — login is
# required to submit enquiries on those portals.
# If you provide credentials here (or as GitHub Secrets), the bot will log in
# automatically before submitting.  Leave blank to skip (listings will appear
# in Telegram as "Requires login — enquire manually").
# OnTheMarket does NOT need credentials — its form works without login.
RIGHTMOVE_EMAIL=
RIGHTMOVE_PASSWORD=

# Zoopla and OnTheMarket: use your Gmail account (sign in with Google)
ZOOPLA_EMAIL=
ZOOPLA_PASSWORD=
OTM_EMAIL=
OTM_PASSWORD=
