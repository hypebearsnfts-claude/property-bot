# ── Telegram ─────────────────────────────────────────────────────────────────
# Create a bot via @BotFather on Telegram and paste the token here.
# All three variables should use the same token (one bot handles everything).
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_RESEARCH_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_FILTER_BOT_TOKEN=your-telegram-bot-token

# Your personal Telegram chat ID (send /start to @userinfobot to find it).
TELEGRAM_RESEARCH_CHAT_ID=your-chat-id
TELEGRAM_FILTER_CHAT_ID=your-chat-id

# ── Google Maps ───────────────────────────────────────────────────────────────
# Used for walk-time calculations to nearest tube station.
# Create a key at https://console.cloud.google.com → enable "Distance Matrix API".
GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# ── Anthropic ─────────────────────────────────────────────────────────────────
# Used for AI-powered FMV valuation.
# Get a key at https://console.anthropic.com
ANTHROPIC_API_KEY=your-anthropic-api-key

# ── Filter bot limits ─────────────────────────────────────────────────────────
# Max listings to send per Telegram run (0 = no limit).
MAX_LISTINGS_SEND=0

# Max walk time to nearest tube station in minutes.
MAX_WALK_MINS=12
